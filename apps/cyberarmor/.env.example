# CyberArmor — local development environment variables
# Copy to .env and fill in real values for production.

# Frontend
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_LOCALE=en

# Backend
APP_ENV=development
APP_SECRET_KEY=change-me-in-production-min-32-chars-long
API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
DATABASE_URL=postgresql+asyncpg://cyberarmor:cyberarmor@postgres:5432/cyberarmor
POSTGRES_USER=cyberarmor
POSTGRES_PASSWORD=cyberarmor
POSTGRES_DB=cyberarmor

# Cache / Session
REDIS_URL=redis://redis:6379/0

# Payment integrations — sandbox/testnet keys only in development
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
BTCPAY_SERVER_URL=
BTCPAY_STORE_ID=
BTCPAY_API_KEY=

# Fulfillment / CRM placeholders
DHL_API_KEY=
FEDEX_API_KEY=
UPS_API_KEY=
SALESFORCE_WEBHOOK_URL=
HUBSPOT_API_KEY=
ZENDESK_SUBDOMAIN=
ZENDESK_API_TOKEN=

# Security
HSTS_MAX_AGE=31536000
CSP_NONCE_ENABLED=false
